{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Proactive Inspection to AIOps Handoff",
  "description": "Payload from qcloud-proactive-inspection for P1 validation (cross-skill-orchestration.md §2.2)",
  "type": "object",
  "required": ["handoff_id", "source_skill", "inspection_id", "findings"],
  "properties": {
    "handoff_id": { "type": "string" },
    "source_skill": { "type": "string", "const": "qcloud-proactive-inspection" },
    "inspection_id": { "type": "string" },
    "findings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["resource_type", "resource_id", "severity", "rule"],
        "properties": {
          "resource_type": { "type": "string" },
          "resource_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["CRITICAL", "HIGH", "MEDIUM", "LOW"] },
          "rule": { "type": "string" },
          "metric": { "type": "string" },
          "value": { "type": "string" },
          "detected_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "report_path": { "type": "string" }
  }
}
