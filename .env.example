# Tencent Cloud Skills — local environment template
# Copy to .env and fill in values. DO NOT commit .env to git.
#
#   cp .env.example .env
#
# Priority: shell export > .env file > code defaults
# Custom path: COPILOT_DOTENV_PATH=/path/to/.env

# ========================================
# Required: Tencent Cloud API credentials
# ========================================
# Console → 访问管理 → API 密钥管理
# https://console.cloud.tencent.com/cam/capi
TENCENTCLOUD_SECRET_ID=your_secret_id_here
TENCENTCLOUD_SECRET_KEY=your_secret_key_here

# Default region for tccli / Copilot / proactive-inspection
TENCENTCLOUD_REGION=ap-guangzhou

# ========================================
# Optional: FinOps skill
# ========================================
# Path to finops YAML config (only for qcloud-finops-ops)
# TENCENTCLOUD_FINOPS_CONFIG=/path/to/finops-config.yaml

# ========================================
# Copilot — customer / region discovery
# ========================================
# Tag key on cloud resources identifying the customer/tenant
COPILOT_CUSTOMER_TAG_KEY=客户

# Comma-separated region allowlist for ask_user / region scan
# COPILOT_REGION_ALLOWLIST=ap-guangzhou,ap-shanghai,ap-beijing

# Explicit regions for topology scan (overrides defaults when set)
# COPILOT_SCAN_REGIONS=ap-guangzhou,ap-shanghai

# ========================================
# Copilot — inspection mode
# ========================================
# auto (default) | delivery | ci
COPILOT_INSPECTION_MODE=auto

# 1 = allow external LLM for CI strategy; 0 = topology heuristic only
COPILOT_LLM_REASONING=0

# Extra NL trigger words for CI mode (comma-separated)
# COPILOT_CI_TRIGGER_WORDS=夜间巡检,weekly-cruise

# ========================================
# Copilot — LLM (OpenAI-compatible, optional)
# ========================================
# COPILOT_LLM_API_KEY=your_llm_api_key_here
# COPILOT_LLM_BASE_URL=https://api.openai.com/v1
# COPILOT_LLM_MODEL=gpt-4o-mini
# COPILOT_LLM_TIMEOUT=300
#
# Domestic examples:
# COPILOT_LLM_BASE_URL=https://api.deepseek.com/v1
# COPILOT_LLM_MODEL=deepseek-chat
# COPILOT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# COPILOT_LLM_MODEL=qwen-plus

# ========================================
# Copilot — interactive gates
# ========================================
# Non-TTY default for ask_user steps: first | (unset = fail-fast)
# COPILOT_ASK_DEFAULT=first

# ========================================
# Dotenv path override (optional)
# ========================================
# COPILOT_DOTENV_PATH=/absolute/path/to/.env
# TENCENTCLOUD_DOTENV_PATH=/absolute/path/to/.env
